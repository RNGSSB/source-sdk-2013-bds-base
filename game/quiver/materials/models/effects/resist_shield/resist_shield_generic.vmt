"VertexLitGeneric"
{
	"$baseTexture" "models\effects\resist_shield\resist_shield_generic"
	"$translucent" "1"
	"$additive" "1"
	//"$bumpmap" "models/effects/flat_normal"

	"$phong" "1"	
	"$lightwarptexture" "models\effects\resist_shield\resist_shield_lightwarp"
	"$phongfresnelranges"	"[.3 .5 .6]"
	"$halflambert" "1"

	// Rim lighting parameters
	"$rimlight" "1"												// To enable rim lighting (requires phong)
	"$rimlightexponent" "4"										// Exponent for phong component of rim lighting	
	"$rimlightboost" "7"										// Boost for ambient cube component of rim lighting
	"$selfillumfresnel" "3"

	"$selfillumfresnelminmaxexp" "[0 1 1]"
	"$selfillum" "1"
	
	"$selfillumtint" "[-0.3 -0.3 -0.3]"
	"$selfillumtint_base" "[0.3 0.3 0.3]"
	"$shield_falloff" 0.0
	
	// Cloaking
	"$cloakPassEnabled" "1"
	"$cloakColorTintFactor"	"0.0"

	"Proxies"
	{
		"invis"
		{
		}
		"ShieldFalloff"
		{
			"resultVar"	"$shield_falloff"
		}
		"Multiply"
		{
			"srcVar1"	"$shield_falloff"
			"srcVar2"	"$selfillumtint_base"
			"resultVar"	"$selfillumtint"
		}
	}
}